<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mapper.CarMapper">
  <select id="selectAllCar" resultType="dto.CarDTO">
  	select 
  		car_id as carId, brand, model, year, 
  		mileage, price, registered_at as registeredAt 
  	from 
  		cars
  </select>
</mapper>