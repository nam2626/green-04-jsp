<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-config.dtd">
<!-- 
    MyBatis의 핵심 설정 파일입니다.
    DB 접속 정보와 어떤 Mapper 파일을 사용할지 등을 정의합니다.
-->
<configuration>
	<!-- 자주 사용하는 클래스에 대해 짧은 별칭(Alias)을 설정합니다. -->
	<typeAliases>
		<!-- dto.MemberDTO 클래스를 앞으로 SQL 매퍼에서 'member'라는 이름으로 부릅니다. -->
		<typeAlias type="dto.MemberDTO" alias="member"/>
	</typeAliases>
	
	<!-- DB 접속 환경 설정 -->
	<environments default="development">
		<environment id="development">
			<!-- 트랜잭션 관리는 JDBC 방식을 따릅니다. -->
			<transactionManager type="JDBC"/>
			<!-- 커넥션 풀(POOLED)을 사용하여 DB 연결을 효율적으로 관리합니다. -->
			<dataSource type="POOLED">
				<property name="driver" value="com.mysql.cj.jdbc.Driver"/>
				<property name="url" value="jdbc:mysql://localhost:3306/board_db"/>
				<property name="username" value="root"/>
				<property name="password" value="12345678"/>
			</dataSource>
		</environment>
	</environments>
  
	<mappers>
		<!-- 실제 SQL문이 작성되어 있는 Mapper 파일의 위치를 등록합니다. -->
		<mapper resource="config/member-mapper.xml"/>
	</mappers>
</configuration>
