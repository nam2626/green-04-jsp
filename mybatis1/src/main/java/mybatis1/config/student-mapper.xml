<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mybatis1.mapper.StudentMapper">
	<select id="selectAllStudent" resultType="mybatis1.dto.StudentDTO1">
		select * from students
	</select>
	<select id="selectForName" resultType="mybatis1.dto.StudentDTO1">
		select * from students where name like concat('%',#{name},'%')
	</select>
	<select id="selectForNo" resultType="mybatis1.dto.StudentDTO1">
		select * from students where student_id = #{id}
	</select>
</mapper>